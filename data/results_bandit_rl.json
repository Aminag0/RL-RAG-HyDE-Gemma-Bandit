    {
      "episode": 2,
      "question_num": 7,
      "question": "What is the Big Bang theory and what evidence supports it?",
      "selected_arm": "HyDE_k3",
      "method": "HyDE",
      "k": 3,
      "decision_type": "exploit",
      "reward_rqm": 0.41432425728743516,
      "updated_q_value": 0.49453201313759737,
      "arm_count": 3,
      "time_seconds": 9.01157283782959,
      "hypothetical_doc": "**The Big Bang Theory:** The prevailing cosmological model posits that the universe originated from an extremely hot, dense state approximately 13.7 billion years ago through a rapid expansion – the “Big Bang.” This event initiated significant energy release and subsequent cooling, leading to the formation of particles and eventually matter.\n\n**Evidence Supporting It:** Cosmic microwave background radiation (a faint afterglow), redshift in distant galaxies, abundance of light elements like hydrogen and helium, and general uniformity across space all point towards a universe originating from an initial singularity – compelling evidence for its evolution.”"
    },
    {
      "episode": 2,
      "question_num": 8,
      "question": "How does nuclear fusion work in stars?",
      "selected_arm": "HyDE_k1",
